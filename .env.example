# Vibe-Import Configuration
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (recommended - has free models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI API Key (optional)
# OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM Provider (openrouter, openai, anthropic)
# VIBE_IMPORT_PROVIDER=openrouter

# Model name (optional, uses provider default if not set)
# VIBE_IMPORT_MODEL=qwen/qwen3-coder:free

# Generation temperature (0-1, lower = more deterministic)
# VIBE_IMPORT_TEMPERATURE=0.2

# Maximum tokens in response
# VIBE_IMPORT_MAX_TOKENS=8192